      {
        "name": "_Measures",
        "columns": [
          {
            "name": "_placeholder",
            "dataType": "string",
            "sourceColumn": "_placeholder",
            "isHidden": true
          }
        ],
        "measures": [
          {
            "name": "Total Org Determinations Override",
            "expression": "COUNTROWS(FactDetermination)",
            "description": "Total count of unique Organization Determinations."
          },
          {
            "name": "Adverse Decision Rate",
            "expression": "DIVIDE(CALCULATE(COUNTROWS(FactDetermination), FactDetermination[disposition] = \"Adverse\"), [Total Org Determinations Override], 0)",
            "description": "Percentage of determinations that resulted in adverse decisions."
          }
        ],
        "partitions": [
