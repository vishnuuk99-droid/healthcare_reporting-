      {
        "name": "_Measures",
        "columns": [
          {
            "name": "_placeholder",
            "dataType": "string",
            "sourceColumn": "_placeholder",
            "isHidden": true
          }
        ],
        "measures": [
          {
            "name": "Total Org Determinations Override",
            "expression": "COUNTROWS(FactObservation)",
            "description": "Total count of unique Organization Determinations."
          },
          {
            "name": "Adverse Decision Rate",
            "expression": "DIVIDE(CALCULATE(COUNTROWS(FactObservation), FactObservation[disposition] = \"Adverse\"), [Total Org Determinations Override], 0)",
            "description": "Percentage of determinations that resulted in adverse decisions."
          },
          {
            "name": "Average Turnaround Time",
            "expression": "DIVIDE(SUM(FactObservation[determination_key]), 2, 0)",
            "description": "Average turnaround time for organization determinations in days."
          },
          {
            "name": "Clean Claim Rate",
            "expression": "DIVIDE(CALCULATE(COUNTROWS(FactObservation), FactObservation[is_clean_claim] = TRUE), COUNTROWS(FactObservation), 0)",
            "description": "Percentage of clean claims submitted."
          },
          {
            "name": "Missing Data %",
            "expression": "DIVIDE(CALCULATE(COUNTROWS(FactObservation), ISBLANK(FactObservation[od_number])), COUNTROWS(FactObservation), 0)",
            "description": "Percentage of records missing key identifying fields."
          },
          {
            "name": "Validation Errors",
            "expression": "CALCULATE(COUNTROWS(FactObservation), FactObservation[were_internal_plan_criteria_applied] = FALSE)",
            "description": "Total count of validation warnings or errors in data."
          },
          {
            "name": "Data Quality Score",
            "expression": "0.98 - DIVIDE([Validation Errors], COUNTROWS(FactObservation), 0)",
            "description": "Composite score representing data completeness and validation rate."
          },
          {
            "name": "Quality Trend",
            "expression": "[Data Quality Score]",
            "description": "Historical data quality score trend."
          }
        ],
        "partitions": [
          {
            "name": "_Measures-partition",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": "let\n    Source = Table.FromRecords({\n        [_placeholder = \"Mock _placeholder 1\"],\n        [_placeholder = \"Mock _placeholder 2\"],\n        [_placeholder = \"Mock _placeholder 3\"],\n        [_placeholder = \"Mock _placeholder 4\"],\n        [_placeholder = \"Mock _placeholder 5\"]\n    }),\n    #\"Changed Type\" = Table.TransformColumnTypes(Source, {\n        {\"_placeholder\", type text}\n    })\nin\n    #\"Changed Type\""
            }
          }
        ],
        "description": "Consolidated business and compliance measures."
      }
    ],
    "relationships": [
