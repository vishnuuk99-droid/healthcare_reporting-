alue_boolean = false, value_quantity = 6.0, decision_rationale = \"Mock decision_rationale 4\", dismissal_rationale = \"Mock dismissal_rationale 4\", processing_priority = \"Mock processing_priority 4\"],\n        [observation_key = 5, patient_key = 5, provider_key = 5, organization_key = 5, date_key = 20260515, observation_identifier = \"Mock observation_identifier 5\", observation_code = \"Mock observation_code 5\", observation_status = \"Mock observation_status 5\", value_codeable_concept = \"Mock value_codeable_concept 5\", value_boolean = true, value_quantity = 7.5, decision_rationale = \"Mock decision_rationale 5\", dismissal_rationale = \"Mock dismissal_rationale 5\", processing_priority = \"Mock processing_priority 5\"]\n    }),\n    #\"Changed Type\" = Table.TransformColumnTypes(Source, {\n        {\"observation_key\", type text},\n        {\"patient_key\", type text},\n        {\"provider_key\", type text},\n        {\"organization_key\", type text},\n        {\"date_key\", type text},\n        {\"observation_identifier\", type text},\n        {\"observation_code\", type text},\n        {\"observation_status\", type text},\n        {\"value_codeable_concept\", type text},\n        {\"value_boolean\", type logical},\n        {\"value_quantity\", type number},\n        {\"decision_rationale\", type text},\n        {\"dismissal_rationale\", type text},\n        {\"processing_priority\", type text}\n    })\nin\n    #\"Changed Type\""
