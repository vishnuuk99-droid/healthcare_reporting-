model Model
	compatibilityLevel: 1570
	culture: en-US

table FactObservation
	// Description: Captures operational quality events, grievances, organization determinations, reconsiderations, health risk assessments (HRAs), and provider payments. Strictly isolated from prior authorization metrics and service level data collection reports per organizational decision c19cd11c.
	column observation_key
		dataType: string
		sourceColumn: observation_key
	column patient_key
		dataType: string
		sourceColumn: patient_key
	column provider_key
		dataType: string
		sourceColumn: provider_key
	column organization_key
		dataType: string
		sourceColumn: organization_key
	column date_key
		dataType: string
		sourceColumn: date_key
	column observation_identifier
		dataType: string
		sourceColumn: observation_identifier
	column observation_code
		dataType: string
		sourceColumn: observation_code
	column observation_status
		dataType: string
		sourceColumn: observation_status
	column value_codeable_concept
		dataType: string
		sourceColumn: value_codeable_concept
	column value_boolean
		dataType: boolean
		sourceColumn: value_boolean
	column value_quantity
		dataType: double
		sourceColumn: value_quantity
	column decision_rationale
		dataType: string
		sourceColumn: decision_rationale
	column dismissal_rationale
		dataType: string
		sourceColumn: dismissal_rationale
	column processing_priority
		dataType: string
		sourceColumn: processing_priority
	partition FactObservation-partition = m
		mode: import
		source =
			let
			    Source = Table.FromRecords({
			        [observation_key = 1, patient_key = 1, provider_key = 1, organization_key = 1, date_key = 20260115, observation_identifier = "Mock observation_identifier 1", observation_code = "Mock observation_code 1", observation_status = "Mock observation_status 1", value_codeable_concept = "Mock value_codeable_concept 1", value_boolean = true, value_quantity = 1.5, decision_rationale = "Mock decision_rationale 1", dismissal_rationale = "Mock dismissal_rationale 1", processing_priority = "Mock processing_priority 1"],
			        [observation_key = 2, patient_key = 2, provider_key = 2, organization_key = 2, date_key = 20260220, observation_identifier = "Mock observation_identifier 2", observation_code = "Mock observation_code 2", observation_status = "Mock observation_status 2", value_codeable_concept = "Mock value_codeable_concept 2", value_boolean = false, value_quantity = 3.0, decision_rationale = "Mock decision_rationale 2", dismissal_rationale = "Mock dismissal_rationale 2", processing_priority = "Mock processing_priority 2"],
			        [observation_key = 3, patient_key = 3, provider_key = 3, organization_key = 3, date_key = 20260310, observation_identifier = "Mock observation_identifier 3", observation_code = "Mock observation_code 3", observation_status = "Mock observation_status 3", value_codeable_concept = "Mock value_codeable_concept 3", value_boolean = true, value_quantity = 4.5, decision_rationale = "Mock decision_rationale 3", dismissal_rationale = "Mock dismissal_rationale 3", processing_priority = "Mock processing_priority 3"],
			        [observation_key = 4, patient_key = 4, provider_key = 4, organization_key = 4, date_key = 20260425, observation_identifier = "Mock observation_identifier 4", observation_code = "Mock observation_code 4", observation_status = "Mock observation_status 4", value_codeable_concept = "Mock value_codeable_concept 4", value_boolean = false, value_quantity = 6.0, decision_rationale = "Mock decision_rationale 4", dismissal_rationale = "Mock dismissal_rationale 4", processing_priority = "Mock processing_priority 4"],
			        [observation_key = 5, patient_key = 5, provider_key = 5, organization_key = 5, date_key = 20260515, observation_identifier = "Mock observation_identifier 5", observation_code = "Mock observation_code 5", observation_status = "Mock observation_status 5", value_codeable_concept = "Mock value_codeable_concept 5", value_boolean = true, value_quantity = 7.5, decision_rationale = "Mock decision_rationale 5", dismissal_rationale = "Mock dismissal_rationale 5", processing_priority = "Mock processing_priority 5"]
			    }),
			    #"Changed Type" = Table.TransformColumnTypes(Source, {
			        {"observation_key", type text},
			        {"patient_key", type text},
			        {"provider_key", type text},
			        {"organization_key", type text},
			        {"date_key", type text},
			        {"observation_identifier", type text},
			        {"observation_code", type text},
			        {"observation_status", type text},
			        {"value_codeable_concept", type text},
			        {"value_boolean", type logical},
			        {"value_quantity", type number},
			        {"decision_rationale", type text},
			        {"dismissal_rationale", type text},
			        {"processing_priority", type text}
			    })
			in
			    #"Changed Type"

