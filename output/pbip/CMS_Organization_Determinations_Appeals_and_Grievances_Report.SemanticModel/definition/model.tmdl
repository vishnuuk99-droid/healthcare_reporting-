table DimDate
	// Description: Standard date dimension for time-based analysis of all events.
	column date_key
		dataType: int64
		sourceColumn: date_key
	column full_date
		dataType: dateTime
		sourceColumn: full_date
	column day_of_week
		dataType: string
		sourceColumn: day_of_week
	column day_name
		dataType: string
		sourceColumn: day_name
	column day_of_month
		dataType: int64
		sourceColumn: day_of_month
	column day_of_year
		dataType: int64
		sourceColumn: day_of_year
	column week_of_year
		dataType: int64
		sourceColumn: week_of_year
	column month
		dataType: int64
		sourceColumn: month
	column month_name
		dataType: string
		sourceColumn: month_name
	column quarter
		dataType: int64
		sourceColumn: quarter
	column year
		dataType: int64
		sourceColumn: year
	column is_weekend
		dataType: boolean
		sourceColumn: is_weekend
	column fiscal_period
		dataType: string
		sourceColumn: fiscal_period
	partition DimDate-partition = m
		mode: import
		source =
			let
			    Source = Table.FromRecords({
