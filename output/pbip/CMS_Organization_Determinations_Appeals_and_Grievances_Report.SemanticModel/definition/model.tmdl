			        [date_key = 20260220, full_date = #date(2026, 2, 20), day_of_week = 5, day_name = "Friday", day_of_month = 20, day_of_year = 20, week_of_year = 20, month = 2, month_name = "February", quarter = 1, year = 2026, is_weekend = false, fiscal_period = "Mock fiscal_period 2"],
			        [date_key = 20260310, full_date = #date(2026, 3, 10), day_of_week = 2, day_name = "Tuesday", day_of_month = 30, day_of_year = 30, week_of_year = 30, month = 3, month_name = "March", quarter = 1, year = 2026, is_weekend = true, fiscal_period = "Mock fiscal_period 3"],
			        [date_key = 20260425, full_date = #date(2026, 4, 25), day_of_week = 6, day_name = "Saturday", day_of_month = 40, day_of_year = 40, week_of_year = 40, month = 4, month_name = "April", quarter = 2, year = 2026, is_weekend = false, fiscal_period = "Mock fiscal_period 4"],
			        [date_key = 20260515, full_date = #date(2026, 5, 15), day_of_week = 5, day_name = "Friday", day_of_month = 50, day_of_year = 50, week_of_year = 50, month = 5, month_name = "May", quarter = 2, year = 2026, is_weekend = true, fiscal_period = "Mock fiscal_period 5"]
			    }),
			    #"Changed Type" = Table.TransformColumnTypes(Source, {
