			        {"day_of_week", type text},
			        {"day_name", type text},
			        {"day_of_month", Int64.Type},
			        {"day_of_year", Int64.Type},
			        {"week_of_year", Int64.Type},
			        {"month", Int64.Type},
			        {"month_name", type text},
			        {"quarter", Int64.Type},
			        {"year", Int64.Type},
			        {"is_weekend", type logical},
			        {"fiscal_period", type text}
			    })
			in
			    #"Changed Type"

