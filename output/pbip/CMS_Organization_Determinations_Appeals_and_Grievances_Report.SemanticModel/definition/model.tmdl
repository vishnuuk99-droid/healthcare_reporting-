table DimDate
	// Description: Standard date dimension for time-based analysis and reporting periods.
	column date_key
		dataType: string
		sourceColumn: date_key
	column date
		dataType: dateTime
		sourceColumn: date
	column year
		dataType: int64
		sourceColumn: year
	column quarter
		dataType: string
		sourceColumn: quarter
	column month
		dataType: string
		sourceColumn: month
	column day
		dataType: int64
		sourceColumn: day
	partition DimDate-partition = m
		mode: import
		source =
			let
			    Source = Table.FromRecords({
			        [date_key = 20260115, date = #date(2026, 1, 15), year = 2026, quarter = 1, month = 1, day = 15],
			        [date_key = 20260220, date = #date(2026, 2, 20), year = 2026, quarter = 1, month = 2, day = 20],
			        [date_key = 20260310, date = #date(2026, 3, 10), year = 2026, quarter = 1, month = 3, day = 10],
			        [date_key = 20260425, date = #date(2026, 4, 25), year = 2026, quarter = 2, month = 4, day = 25],
			        [date_key = 20260515, date = #date(2026, 5, 15), year = 2026, quarter = 2, month = 5, day = 15]
			    }),
			    #"Changed Type" = Table.TransformColumnTypes(Source, {
			        {"date_key", type text},
			        {"date", type date},
			        {"year", Int64.Type},
			        {"quarter", type text},
			        {"month", type text},
			        {"day", Int64.Type}
			    })
			in
			    #"Changed Type"

relationship 'FactObservation_DimPatient_patient_key'
	fromTable: FactObservation
	fromColumn: patient_key
	toTable: DimPatient
	toColumn: patient_key
