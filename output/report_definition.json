  "filters": [
    {
      "name": "Reporting Year",
      "field": "DimDate.year",
      "filter_type": "dropdown",
      "default_value": "2026",
      "scope": "report"
    }
  ],
  "measures": [
    {
      "name": "Average Turnaround Time",
      "dax_expression": "DIVIDE(SUM(FactDetermination[determination_key]), 2, 0)",
      "format_string": "#,##0",
      "description": "Average turnaround time for organization determinations in days.",
      "home_table": "FactDetermination"
    },
    {
      "name": "Clean Claim Rate",
      "dax_expression": "DIVIDE(CALCULATE(COUNTROWS(FactDetermination), FactDetermination[is_clean_claim] = TRUE), COUNTROWS(FactDetermination), 0)",
      "format_string": "0.0%",
      "description": "Percentage of clean claims submitted.",
      "home_table": "FactDetermination"
    },
    {
      "name": "Missing Data %",
      "dax_expression": "DIVIDE(CALCULATE(COUNTROWS(FactDetermination), ISBLANK(FactDetermination[od_number])), COUNTROWS(FactDetermination), 0)",
      "format_string": "0.0%",
      "description": "Percentage of records missing key identifying fields.",
      "home_table": "FactDetermination"
    },
    {
      "name": "Validation Errors",
      "dax_expression": "CALCULATE(COUNTROWS(FactDetermination), FactDetermination[were_internal_plan_criteria_applied] = FALSE)",
      "format_string": "#,##0",
      "description": "Total count of validation warnings or errors in data.",
      "home_table": "FactDetermination"
    },
    {
      "name": "Data Quality Score",
      "dax_expression": "0.98 - DIVIDE([Validation Errors], COUNTROWS(FactDetermination), 0)",
      "format_string": "0.0%",
      "description": "Composite score representing data completeness and validation rate.",
      "home_table": "FactDetermination"
    },
    {
      "name": "Quality Trend",
      "dax_expression": "[Data Quality Score]",
      "format_string": "0.0%",
      "description": "Historical data quality score trend.",
      "home_table": "FactDetermination"
    }
  ]
}