  "metrics": [
    {
      "name": "total_grievances",
      "description": "Total number of grievances reported based on the decision date, excluding withdrawn and dismissed grievances.",
      "formula": "COUNT(DISTINCT CASE WHEN observation_code = 'Grievance' AND observation_status = 'completed' AND value_codeable_concept <> 'Dismissal' THEN observation_key END)",
      "fact_table": "FactObservation",
      "dimensions": [
        "DimOrganization.contract_number",
        "DimOrganization.pbp_code",
        "DimPatient.state"
      ]
    },
    {
      "name": "expedited_grievances",
      "description": "Number of expedited grievances.",
      "formula": "COUNT(DISTINCT CASE WHEN observation_code = 'Grievance' AND processing_priority = 'Expedited' THEN observation_key END)",
      "fact_table": "FactObservation",
      "dimensions": [
        "DimOrganization.contract_number",
        "DimPatient.state"
      ]
    },
    {
      "name": "completed_organization_determinations",
      "description": "Number of completed organization determinations categorized by disposition.",
      "formula": "COUNT(DISTINCT CASE WHEN observation_code = 'Organization Determination' AND observation_status = 'completed' THEN observation_key END)",
      "fact_table": "FactObservation",
      "dimensions": [
        "DimOrganization.contract_number",
        "FactObservation.value_codeable_concept"
      ]
    },
    {
      "name": "total_actual_provider_payments",
      "description": "Total actual payments made to contracted providers.",
      "formula": "SUM(CASE WHEN observation_code = 'Provider Payment' THEN value_quantity END)",
      "fact_table": "FactObservation",
      "dimensions": [
        "DimOrganization.contract_number",
        "DimOrganization.line_of_business"
      ]
    },
    {
      "name": "initial_hras_completed",
      "description": "SNP Care Management: Number of initial HRAs completed.",
      "formula": "COUNT(DISTINCT CASE WHEN observation_code = 'Initial HRA' AND observation_status = 'completed' THEN observation_key END)",
      "fact_table": "FactObservation",
      "dimensions": [
        "DimOrganization.contract_number",
        "DimPatient.state"
      ]
    },
    {
      "name": "dsnp_hospital_admissions",
      "description": "Count of hospital and SNF admissions for D-SNP enrollees.",
      "formula": "COUNT(DISTINCT CASE WHEN encounter_class IN ('inpatient', 'SNF stay') THEN encounter_key END)",
      "fact_table": "FactEncounter",
      "dimensions": [
        "DimOrganization.contract_number",
        "DimPatient.state"
      ]
    }
  ],
  "attributes": [
    {
      "name": "Geography",
      "table": "DimPatient",
      "drill_path": [
        "state",
        "patient_key"
      ],
      "description": "Geographic drill-down path for enrollees."
    },
    {
      "name": "Organization Hierarchy",
      "table": "DimOrganization",
      "drill_path": [
        "organization_type",
        "contract_number",
        "pbp_code"
      ],
      "description": "Drill-down path from Organization Type to Contract and Plan Benefit Package."
    },
    {
      "name": "Time Hierarchy",
      "table": "DimDate",
      "drill_path": [
        "year",
        "quarter",
        "month",
        "date"
      ],
      "description": "Standard calendar drill-down path."
    }
  ]
