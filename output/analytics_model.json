        },
        {
          "name": "organization_key",
          "data_type": "VARCHAR",
          "source_fhir_field": "insurance.reference",
          "description": "Foreign key to DimOrganization."
        },
        {
          "name": "date_key",
          "data_type": "VARCHAR",
          "source_fhir_field": "authoredOn",
