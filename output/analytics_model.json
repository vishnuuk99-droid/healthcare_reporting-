{
  "fact_tables": [
    {
      "name": "FactObservation",
      "source_fhir_resource": "Observation",
      "description": "Captures operational quality events, grievances, organization determinations, reconsiderations, health risk assessments (HRAs), and provider payments. Strictly isolated from prior authorization metrics and service level data collection reports per organizational decision c19cd11c.",
      "grain": "One observation event (e.g., a grievance decision, a determination outcome, an HRA completion, or a payment record)",
      "columns": [
        {
          "name": "observation_key",
          "data_type": "VARCHAR",
          "source_fhir_field": "id",
          "description": "Surrogate key for the observation record."
        },
        {
          "name": "patient_key",
          "data_type": "VARCHAR",
          "source_fhir_field": "subject.reference",
          "description": "Foreign key to DimPatient."
        },
        {
          "name": "provider_key",
          "data_type": "VARCHAR",
          "source_fhir_field": "performer.reference",
          "description": "Foreign key to DimProvider."
        },
        {
          "name": "organization_key",
          "data_type": "VARCHAR",
          "source_fhir_field": "performer.reference",
          "description": "Foreign key to DimOrganization."
        },
        {
          "name": "date_key",
          "data_type": "VARCHAR",
          "source_fhir_field": "effectiveDateTime",
          "description": "Foreign key to DimDate representing the event date."
        },
        {
          "name": "observation_identifier",
          "data_type": "VARCHAR",
          "source_fhir_field": "identifier",
          "description": "Business identifier (e.g., Organization Determination Number, Appeal Number)."
        },
        {
          "name": "observation_code",
          "data_type": "VARCHAR",
          "source_fhir_field": "code",
          "description": "Coded type of observation (e.g., Grievance, Initial Determination, Reconsideration, HRA, Payment)."
        },
        {
          "name": "observation_status",
          "data_type": "VARCHAR",
          "source_fhir_field": "status",
          "description": "Completion status of the observation (e.g., final, completed)."
        },
        {
          "name": "value_codeable_concept",
          "data_type": "VARCHAR",
          "source_fhir_field": "valueCodeableConcept",
          "description": "Coded result value (e.g., Disposition like Fully Favorable, Adverse, Dismissal)."
        },
        {
          "name": "value_boolean",
          "data_type": "BOOLEAN",
          "source_fhir_field": "valueBoolean",
          "description": "Boolean result flag (e.g., Was expedited requested, Was clean claim)."
        },
        {
          "name": "value_quantity",
          "data_type": "DECIMAL",
          "source_fhir_field": "valueQuantity",
          "description": "Numeric value (e.g., Payment amount, Out-of-pocket cost)."
        },
        {
          "name": "decision_rationale",
          "data_type": "VARCHAR",
          "source_fhir_field": "valueCodeableConcept",
          "description": "Descriptive reason for the decision. Numerical prefixes are removed per organizational decisions 4fac028f and 95cb9416."
        },
        {
          "name": "dismissal_rationale",
          "data_type": "VARCHAR",
          "source_fhir_field": "valueCodeableConcept",
          "description": "Coded reason for dismissal of a grievance or coverage request."
        },
        {
          "name": "processing_priority",
          "data_type": "VARCHAR",
          "source_fhir_field": "valueCodeableConcept",
          "description": "Priority of processing (e.g., Standard, Expedited)."
        }
      ]
    },
    {
