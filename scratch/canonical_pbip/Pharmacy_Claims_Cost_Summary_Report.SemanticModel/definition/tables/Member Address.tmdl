	column date_of_birth
		dataType: dateTime
		isHidden
		formatString: Long Date
		lineageTag: 27b125e7-7049-45d5-844f-4ce042810194
		summarizeBy: none
		sourceColumn: date_of_birth

		variation Variation
			isDefault
			relationship: afe4ad22-5c0e-499b-9088-9d960900e691
			defaultHierarchy: LocalDateTable_8af95df4-344a-4e09-8bf9-d6edc45c554f.'Date Hierarchy'

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

	/// Age group based on date_of_birth. Handles DOB=1900 as Unknown.
	column 'Age Group' =
			VAR _age = DATEDIFF('Member Address'[date_of_birth], TODAY(), YEAR)
			RETURN
			    IF(
			        'Member Address'[date_of_birth] = DATE(1900,1,1), "Unknown",
			        IF(_age <= 17,  "Child (0-17)",
			        IF(_age <= 35,  "Young Adult (18-35)",
			        IF(_age <= 50,  "Adult (36-50)",
			        IF(_age <= 64,  "Middle Aged (51-64)",
			        "Senior (65+)"))))
			    )
		dataType: string
		displayFolder: Demographics
		lineageTag: ec5ae168-2617-4fd7-99d7-fabedb3d5222
		summarizeBy: none

	/// Sort order for Age Group column so it sorts correctly in visuals.
	column 'Age Group Sort' =
			SWITCH(
			    'Member Address'[Age Group],
			    "Child (0-17)",        1,
			    "Young Adult (18-35)", 2,
			    "Adult (36-50)",       3,
			    "Middle Aged (51-64)", 4,
			    "Senior (65+)",        5,
			    "Unknown",             6
			)
		dataType: int64
		isHidden
		displayFolder: Demographics
		lineageTag: e6faf07d-046a-4f77-9abf-b30bbd7e6d2c
		summarizeBy: none

	partition 'Sheet1 (3)' = m
		mode: import
		source =
				let
				    Source = Excel.Workbook(File.Contents("C:\Users\uvishnu\OneDrive - ZeOmega\Desktop\Member_Address.xlsx"), null, true),
				    Sheet1_Sheet = Source{[Item="Sheet1",Kind="Sheet"]}[Data],
				    #"Promoted Headers" = Table.PromoteHeaders(Sheet1_Sheet, [PromoteAllScalars=true]),
				    #"Changed Type" = Table.TransformColumnTypes(#"Promoted Headers",{{"Member_Id", Int64.Type}, {"City", type text}, {"STATE", type text}, {"ZIP", Int64.Type}, {"date_of_birth", type date}})
				in
				    #"Changed Type"

	annotation PBI_ResultType = Table

