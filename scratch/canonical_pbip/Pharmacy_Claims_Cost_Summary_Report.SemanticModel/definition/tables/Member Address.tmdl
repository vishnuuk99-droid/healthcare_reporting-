	column STATE
		dataType: string
		lineageTag: fc5ecf66-191a-4954-ba69-7de0e849de1c
		dataCategory: StateOrProvince
		summarizeBy: none
		sourceColumn: STATE

		annotation SummarizationSetBy = Automatic

	column ZIP
		dataType: int64
		formatString: 0
		lineageTag: f66814aa-8084-47a9-9cac-dd176f45737b
		dataCategory: PostalCode
		summarizeBy: none
		sourceColumn: ZIP

